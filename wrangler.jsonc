{
  "name": "cm-data",
  "main": "worker/src/index.js",
  "compatibility_date": "2026-02-15",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "worker/site",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "rmc14stats.com/*",
      "custom_domain": true
    },
    {
      "pattern": "www.rmc14stats.com/*",
      "custom_domain": true
    }
  ]
}
