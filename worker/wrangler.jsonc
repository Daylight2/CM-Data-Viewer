{
  "name": "cm-data-viewer",
  "main": "src/index.js",
  "compatibility_date": "2026-02-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./site",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": ["*/30 * * * *"]
  }
}
